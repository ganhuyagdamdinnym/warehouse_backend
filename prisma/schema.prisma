generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Checkin ──────────────────────────────────────────────────────────────────

model Checkin {
  id         Int           @id @default(autoincrement())
  code       String        @unique @db.VarChar(20)
  date       DateTime      @db.Date
  status     CheckinStatus @default(Draft)
  contact    String?       @db.VarChar(100)
  warehouse  String?       @db.VarChar(100)
  user       String?       @db.VarChar(100)
  details    String?       @db.Text
  created_at DateTime      @default(now())
  items      CheckinItem[]

  @@map("checkins")
}

model CheckinItem {
  id         Int     @id @default(autoincrement())
  checkin_id Int
  itemId     Int
  name       String? @db.VarChar(100)
  code       String? @db.VarChar(50)
  quantity   String? @db.VarChar(50)
  checkin    Checkin @relation(fields: [checkin_id], references: [id], onDelete: Cascade)

  @@map("checkin_items")
}

// ─── Checkout ─────────────────────────────────────────────────────────────────

model Checkout {
  id          Int            @id @default(autoincrement())
  code        String         @unique @db.VarChar(20)
  date        DateTime       @db.Date
  status      CheckoutStatus @default(Draft)
  contact     String?        @db.VarChar(100)
  warehouseId Int
  warehouse   String?        @db.VarChar(100)
  user        String?        @db.VarChar(100)
  details     String?        @db.Text
  created_at  DateTime       @default(now())
  items       CheckoutItem[]

  @@map("checkouts")
}

model CheckoutItem {
  id          Int      @id @default(autoincrement())
  checkout_id Int
  itemId      Int
  item        Item     @relation(fields: [itemId], references: [id])
  name        String?  @db.VarChar(100)
  code        String?  @db.VarChar(50)
  quantity    String?  @db.VarChar(50)
  checkout    Checkout @relation(fields: [checkout_id], references: [id], onDelete: Cascade)

  @@map("checkout_items")
}

// ─── Contact ──────────────────────────────────────────────────────────────────

model Contact {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String?  @db.VarChar(100)
  phone      String?  @db.VarChar(50)
  details    String?  @db.Text
  created_at DateTime @default(now())

  @@map("contacts")
}

// ─── Warehouse ────────────────────────────────────────────────────────────────



model Warehouse {
  id          Int              @id @default(autoincrement())
  code        String           @unique @db.VarChar(50)
  name        String           @db.VarChar(100)
  logoImage   String?          @db.Text
  phone       String?          @db.VarChar(50)
  email       String?          @db.VarChar(100)
  address     String?          @db.Text
  is_active   Boolean?         @default(false)
  created_at  DateTime         @default(now())
  stockLedger WarehouseStock[]

  // Энэ хоёр мөрийг нэмээрэй:
  transfersFrom Transfer[] @relation("FromWarehouse")
  transfersTo   Transfer[] @relation("ToWarehouse")

  @@map("warehouses")
}

model Stock {
  id          Int   @id @default(autoincrement())
  productId   Int // Барааны ID
  warehouseId Int // Агуулахын ID
  quantity    Float // Одоо байгаа тоо

  @@unique([productId, warehouseId])
}

// ─── Item ─────────────────────────────────────────────────────────────────────

model Item {
  id              Int              @id @default(autoincrement())
  name            String           @db.VarChar(100)
  internalCode    String?          @db.VarChar(50)
  barcode         String?          @db.VarChar(50)
  barcodeType     String?          @db.VarChar(20)
  sku             String?          @db.VarChar(50)
  category        String?          @db.VarChar(50)
  unit            String?          @db.VarChar(20)
  location        String?          @db.VarChar(50)
  description     String?          @db.Text
  image           String?          @db.Text
  trackStock      Boolean          @default(false)
  stock           Int              @default(0) // Нийт үлдэгдэл (бүх агуулахын нийлбэр)
  stockAlert      Int?
  createdAt       DateTime         @default(now())
  warehouseStocks WarehouseStock[]
  stockMovements  StockMovement[]
  checkoutItems   CheckoutItem[]

  @@map("items")
}

// ─── WarehouseStock — агуулах тус бүрийн үлдэгдэл ───────────────────────────

model WarehouseStock {
  id          Int       @id @default(autoincrement())
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId Int
  quantity    Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([itemId, warehouseId])
  @@map("warehouse_stocks")
}

// ─── StockMovement — бүх хөдөлгөөний түүх ───────────────────────────────────

model StockMovement {
  id            Int          @id @default(autoincrement())
  item          Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId        Int
  type          MovementType
  quantity      Int // Эерэг = нэмэгдсэн, сөрөг = хасагдсан
  warehouseFrom String?      @db.VarChar(100)
  warehouseTo   String?      @db.VarChar(100)
  referenceId   Int?
  referenceCode String?      @db.VarChar(30)
  note          String?      @db.VarChar(255)
  createdAt     DateTime     @default(now())

  @@map("stock_movements")
}

// ─── Transfer ─────────────────────────────────────────────────────────────────

model Transfer {
  id              Int            @id @default(autoincrement())
  code            String         @unique @db.VarChar(20)
  date            DateTime       @db.Date
  status          TransferStatus @default(Draft)
  fromWarehouseId Int // String-ийн оронд Int ID ашиглах
  toWarehouseId   Int
  // Relations
  fromWarehouse   Warehouse      @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse      @relation("ToWarehouse", fields: [toWarehouseId], references: [id])

  user       String?        @db.VarChar(100)
  details    String?        @db.Text
  created_at DateTime       @default(now())
  items      TransferItem[]

  @@map("transfers")
}

model TransferItem {
  id          Int      @id @default(autoincrement())
  transfer_id Int
  name        String?  @db.VarChar(100)
  code        String?  @db.VarChar(50)
  itemId      Int // Item-тэй шууд холбох
  quantity    Int // String-ийг Int болгох
  unit        String?  @db.VarChar(50)
  transfer    Transfer @relation(fields: [transfer_id], references: [id], onDelete: Cascade)

  @@map("transfer_items")
}

// ─── Unit ─────────────────────────────────────────────────────────────────────

model Unit {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  code      String   @db.VarChar(20)
  parentId  Int?
  parent    Unit?    @relation("UnitParent", fields: [parentId], references: [id])
  children  Unit[]   @relation("UnitParent")
  createdAt DateTime @default(now())

  @@map("units")
}

// ─── Adjustment ───────────────────────────────────────────────────────────────

model Adjustment {
  id         Int              @id @default(autoincrement())
  code       String?          @db.VarChar(30)
  date       DateTime
  status     String           @default("Draft")
  contact    String?          @db.VarChar(100)
  warehouse  String?          @db.VarChar(100)
  details    String?          @db.Text
  items      AdjustmentItem[]
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  @@map("adjustments")
}

model AdjustmentItem {
  id           Int        @id @default(autoincrement())
  adjustment   Adjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  adjustmentId Int
  name         String     @db.VarChar(100)
  weight       Float      @default(1)
  quantity     Float      @default(1)
  unit         String     @default("Ширхэг") @db.VarChar(50)

  @@map("adjustment_items")
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(100)
  code       String?    @unique @db.VarChar(50)
  parent     Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  parentId   Int?
  children   Category[] @relation("CategoryChildren")
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  @@map("categories")
}

// ─── Role & Permissions ───────────────────────────────────────────────────────

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique @db.VarChar(100)
  permissions RolePermission[]
  users       User[]
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  @@map("roles")
}

model RolePermission {
  id        Int     @id @default(autoincrement())
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId    Int
  module    String  @db.VarChar(50)
  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  @@unique([roleId, module])
  @@map("role_permissions")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id         Int            @id @default(autoincrement())
  name       String         @db.VarChar(50)
  userName   String         @db.VarChar(50)
  email      String?        @unique @db.VarChar(100)
  phone      String?        @db.VarChar(50)
  warehouse  String         @db.VarChar(100)
  password   String         @db.VarChar(100)
  image      String?        @db.Text
  permission UserPermission @default(nothing)
  superAdmin Boolean        @default(false)
  createdAt  DateTime       @default(now())
  roleId     Int?
  role       Role?          @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@map("users")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TransferStatus {
  Draft
  Completed
  Pending
}

enum UserPermission {
  canView
  canEdit
  nothing
}

enum CheckinStatus {
  Draft
  Completed
  Pending
}

enum AdjustmentStatus {
  Draft
  Completed
  Pending
}

enum CheckoutStatus {
  Draft
  Completed
  Pending
}

enum MovementType {
  CHECKIN
  CHECKOUT
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT
}
