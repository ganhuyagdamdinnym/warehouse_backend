generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Checkin {
  id         Int           @id @default(autoincrement())
  code       String        @unique @db.VarChar(20)
  date       DateTime      @db.Date
  status     CheckinStatus @default(Draft)
  contact    String?       @db.VarChar(100)
  warehouse  String?       @db.VarChar(100)
  user       String?       @db.VarChar(100)
  details    String?       @db.Text
  created_at DateTime      @default(now())
  items      CheckinItem[]

  @@map("checkins")
}

model CheckinItem {
  id         Int     @id @default(autoincrement())
  checkin_id Int
  name       String? @db.VarChar(100)
  code       String? @db.VarChar(50)
  weight     String? @db.VarChar(50)
  quantity   String? @db.VarChar(50)
  checkin    Checkin @relation(fields: [checkin_id], references: [id], onDelete: Cascade)

  @@map("checkin_items")
}

model Checkout {
  id         Int            @id @default(autoincrement())
  code       String         @unique @db.VarChar(20)
  date       DateTime       @db.Date
  status     CheckoutStatus @default(Draft)
  contact    String?        @db.VarChar(100)
  warehouse  String?        @db.VarChar(100)
  user       String?        @db.VarChar(100)
  details    String?        @db.Text
  created_at DateTime       @default(now())
  items      CheckoutItem[]

  @@map("checkouts")
}

model CheckoutItem {
  id          Int      @id @default(autoincrement())
  checkout_id Int
  name        String?  @db.VarChar(100)
  code        String?  @db.VarChar(50)
  weight      String?  @db.VarChar(50)
  quantity    String?  @db.VarChar(50)
  checkout    Checkout @relation(fields: [checkout_id], references: [id], onDelete: Cascade)

  @@map("checkout_items")
}

model Contact {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String?  @db.VarChar(100)
  phone      String?  @db.VarChar(50)
  details    String?  @db.Text
  created_at DateTime @default(now())

  @@map("contacts")
}

model Warehouse {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(50)
  name       String   @db.VarChar(100)
  phone      String?  @db.VarChar(50)
  email      String?  @db.VarChar(100)
  address    String?  @db.Text
  is_active  Int      @default(1)
  created_at DateTime @default(now())

  @@map("warehouses")
}

model User{
  id Int @id @default(autoincrement())
  name String @db.VarChar(50)
  userName String @db.VarChar(50)
  email String? @unique @db.VarChar(50)
  phone String? @db.VarChar(50)
  warehouse String @db.VarChar(100)
  password String @db.VarChar(100)
  permission UserPermission @default(nothing)
  superAdmin Boolean @default(false)
    createdAt  DateTime       @default(now())
  @@map("users")
}

model Item {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  internalCode String?  @db.VarChar(50)
  barcode      String?  @db.VarChar(50)
  barcodeType  String?  @db.VarChar(20)
  sku          String?  @db.VarChar(50)
  category     String?  @db.VarChar(50)
  unit         String?  @db.VarChar(20)
  location     String?  @db.VarChar(50)
  description  String?  @db.Text
  image        String?  @db.VarChar(255)
  trackStock   Boolean  @default(false)
  stockAlert   Int?
  createdAt    DateTime @default(now())

  @@map("items")
}
model Transfer {
  id            Int            @id @default(autoincrement())
  code          String         @unique @db.VarChar(20)
  date          DateTime       @db.Date
  status        TransferStatus @default(Draft)
  fromWarehouse String         @db.VarChar(100)
  toWarehouse   String         @db.VarChar(100)
  user          String?        @db.VarChar(100)
  details       String?        @db.Text
  createdAt     DateTime       @default(now())
  items         TransferItem[]

  @@map("transfers")
}

model TransferItem {
  id          Int      @id @default(autoincrement())
  transfer_id Int
  name        String?  @db.VarChar(100)
  code        String?  @db.VarChar(50)
  weight      String?  @db.VarChar(50)
  quantity    String?  @db.VarChar(50)
  unit        String?  @db.VarChar(50)
  transfer    Transfer @relation(fields: [transfer_id], references: [id], onDelete: Cascade)

  @@map("transfer_items")
}
model Unit {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  code       String   @db.VarChar(20)
  parentId   Int?
  parent     Unit?    @relation("UnitParent", fields: [parentId], references: [id])
  children   Unit[]   @relation("UnitParent")
  createdAt  DateTime @default(now())

  @@map("units")
}

