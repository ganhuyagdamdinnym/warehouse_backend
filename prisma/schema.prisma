enum TransferStatus {
  Draft
  Completed
  Pending
}

enum UserPermission {
 canView
 canEdit
 nothing
}

enum CheckinStatus {
  Draft
  Completed
  Pending
}

enum AdjustmentStatus {
  Draft
  Completed
  Pending
}


enum CheckoutStatus {
  Draft
  Completed
  Pending
}


